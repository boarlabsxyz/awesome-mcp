{
  "name": "mcp-googledocs-server",
  "version": "1.0.0",
  "type": "module",
  "main": "index.js",
  "scripts": {
    "build": "tsc",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "test": "node --import tsx --test tests/*.test.js $(find src -name '*.test.ts')",
    "test:watch": "node --import tsx --test --watch tests/*.test.js $(find src -name '*.test.ts')",
    "test:coverage": "c8 --reporter=lcov --reporter=text node --import tsx --test tests/*.test.js $(find src -name '*.test.ts')"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "description": "",
  "dependencies": {
    "bcrypt": "^6.0.0",
    "cookie-parser": "^1.4.7",
    "express": "^5.2.1",
    "fastmcp": "^3.24.0",
    "google-auth-library": "^9.15.1",
    "googleapis": "^148.0.0",
    "http-proxy-middleware": "^3.0.5",
    "ioredis": "^5.9.2",
    "nanoid": "^5.1.6",
    "pg": "^8.17.2",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/bcrypt": "^6.0.0",
    "@types/cookie-parser": "^1.4.10",
    "@types/express": "^5.0.6",
    "@types/node": "^22.14.1",
    "@types/pg": "^8.16.0",
    "c8": "^11.0.0",
    "eslint": "^10.1.0",
    "tsx": "^4.19.3",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.57.1"
  }
}
